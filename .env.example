# ==============================================================
# QiInterview - 环境变量示例
#
# 文件结构（v0.4 重排）：
#   1. 业务凭据（仅 e2e 使用）：LLM Key / Provider / Model、火山语音 API Key 等。
#      业务代码不再从这些字段回退；生产部署完全可以留空。
#      e2e 脚本会读这里的值，再 *模拟* 用户在前端 UI 输入，触发产品的
#      "前端透传"业务路径，确保走的就是真实用户走的代码。
#   2. 服务侧偏好：DB / CORS / 评分阈值 / 面试官音色路由 / 调度器周期 / 后端
#      监听端口。这些是真正的部署级配置，业务代码可以读。
#
# 复制为 .env.local 并填入真实值。
# ==============================================================


# ==============================================================
# (1) 业务凭据 — 仅 e2e 脚本使用，业务代码不读
# ==============================================================

# ---- LLM (OpenAI 兼容，默认豆包/火山方舟) ----
ARK_API_KEY=
LLM_PROVIDER=doubao            # doubao | deepseek | qwen | glm
LLM_MODEL=doubao-seed-1-6-251015
# 模型档位：FAST 用于开场白/出题/评分/印象分/打断/收尾；DEEP 用于复盘报告。
LLM_MODEL_FAST=doubao-1-5-lite-32k-250115
LLM_MODEL_DEEP=doubao-seed-1-6-251015
# 显式关闭 mock；非 pytest 场景下避免 shell 残留 QI_LLM_MOCK=1
QI_LLM_MOCK=0

# ---- 火山引擎语音（新接口：unidirectional HTTPS TTS + bigmodel_async WSS STT）----
# 同一把 X-Api-Key 同时驱动 TTS 和 STT。控制台 → 语音技术 → 应用管理获取。
VOLC_VOICE_KEY=

# ==============================================================
# (2) 服务侧偏好 — 业务代码读取
# ==============================================================

# ---- 火山引擎面试官音色路由（按面试类型）----
# 留空走 backend/app/core/voice_router.py 的 VOICE_MAP 默认；
# 取消注释并填火山控制台音色 ID 即可在不改代码的前提下调整面试官人设。
# 两套命名等价，任选其一（业务上 FIRST=tech1, SECOND=tech2, THIRD=综合, HR=hr）：
# VOLC_VOICE_TYPE_FIRST_ROUND_INTERVIEWER=zh_male_m191_uranus_bigtts
# VOLC_VOICE_TYPE_SECOND_ROUND_INTERVIEWER=zh_male_taocheng_uranus_bigtts
# VOLC_VOICE_TYPE_THIRD_ROUND_INTERVIEWER=zh_male_liufei_uranus_bigtts
# VOLC_VOICE_TYPE_HR_INTERVIEWER=zh_female_xiaohe_uranus_bigtts
#
# 等价短名：
# VOLC_VOICE_TECH1=zh_male_m191_uranus_bigtts
# VOLC_VOICE_TECH2=zh_male_taocheng_uranus_bigtts
# VOLC_VOICE_COMPREHENSIVE=zh_male_liufei_uranus_bigtts
# VOLC_VOICE_HR=zh_female_xiaohe_uranus_bigtts

# ---- 后端 ----
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./data/qiinterview.db
JOBS_REFRESH_INTERVAL_HOURS=6

# ---- 前端 ----
VITE_API_BASE=/api
VITE_WS_BASE=/ws

# ---- P6 / 部署模式与传输安全 ----
# APP_ENV=prod 时 startup 强制要求 COOKIE_SECURE=true 且 ALLOWED_HOSTS
# 必须显式（非 *），并启用 HSTS / CSP 响应头。dev 模式下 cookie_secure 可
# 留 false 让 HTTP 浏览器带回 cookie；ALLOWED_HOSTS 默认 *。
APP_ENV=dev
COOKIE_SECURE=false
ALLOWED_HOSTS=*

# ---- P6 / 邮件发送（注册 OTP + 密码重置链接） ----
# MAIL_BACKEND=console（默认）—— 邮件落 backend/data/dev_mail/<...>.json，
# 本机调试 + e2e 用。生产改 smtp，并填下面这组 SMTP 配置。
MAIL_BACKEND=console
# SMTP 凭据（生产侧，业务代码会读，请放在 .env.local 而不是入库的 .env.example）：
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_SECURITY=starttls          # starttls / ssl / none；生产禁用 none
# MAIL_FROM=noreply@example.com
# 拼接重置 URL 用，必须是用户浏览器能访问到的前端地址：
FRONTEND_BASE_URL=http://127.0.0.1:5173
# 时效与节流（默认 OTP 10min / 重置链接 30min / 同邮箱 60s 内只准发一次）：
MAIL_OTP_TTL_MINUTES=10
MAIL_RESET_TTL_MINUTES=30
MAIL_SEND_MIN_INTERVAL_SEC=60
